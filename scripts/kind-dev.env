# Kind dev environment for Odigos (local-dev-cluster).
# Source before building/loading: source scripts/kind-dev.env
# Then run: ./scripts/build-load-helm-upgrade-kind.sh
# Or use make with: make build-images load-to-kind ... (script passes CLUSTER_NAME to kind load).

export CLUSTER_NAME=local-dev-cluster
export TAG=dev
export ORG=registry.odigos.io
