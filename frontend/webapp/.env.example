# Optional: backend URL when running Next dev.
# (A) Backend in cluster: kubectl port-forward -n <odigos-ns> svc/odigos-ui 8085:3000
#     NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8085
# (B) Backend run locally: from frontend/ run ./odigos-ui (see ODIGOS_UI_DB_PATH, VICTORIA_METRICS_URL)
#     NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:3000
