# Copy to eks-vm-aws.env (gitignored) and fill AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# Fresh EC2: see scripts/bootstrap-ec2-odigos-dev.sh --env-file (copies this file into place).
#   cp scripts/eks-vm-aws.env.example scripts/eks-vm-aws.env
#
# On the VM (e.g. Cursor on ubuntu@Resonance, repo ~/work/odigos):
#   set -a && source scripts/eks-vm-aws.env && set +a
#   ./scripts/eks-mac-vm-eks.sh vm-setup
#
# Prefer ~/.aws/credentials + AWS_PROFILE on machines where you do not use this file.
#
# ECR push (profiler images): ./scripts/aws-ecr-login-from-env.sh public
# Requires IAM: ecr-public:GetAuthorizationToken (see scripts/iam-ecr-profiler-push.json).

export CLUSTER_NAME=eBPF-Profiler-Testbed
export AWS_REGION=ap-southeast-2
export AWS_DEFAULT_REGION=ap-southeast-2
# Dedicated file so Kind (~/.kube/config) and EKS do not share current-context
export KUBECONFIG="${HOME}/.kube/eks-ebpf-profiler.config"
export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=

